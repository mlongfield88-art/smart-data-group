---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
import SectionHeader from '@/components/SectionHeader.astro';
---

<Layout title="About Us" description="Smart Data Group is a comprehensive delivery organisation empowering members to design and implement smart data schemes.">

  <!-- ======== PAGE HERO ======== -->
  <section class="page-hero section-lg">
    <div class="container">
      <p class="text-label reveal">About Us</p>
      <AnimatedText
        tag="h1"
        class="text-display"
        lines={[
          "Empowering the",
          "smart data",
          "ecosystem."
        ]}
      />
      <p class="text-body-lg page-hero__intro reveal">
        Smart Data Group is a comprehensive delivery organisation empowering its members to design and implement smart data schemes while shaping and ensuring compliance with future regulatory requirements.
      </p>
    </div>
  </section>

  <!-- ======== FULL-WIDTH IMAGE ======== -->
  <section class="container">
    <ImagePlaceholder
      alt="Smart Data Group launch event at UK Parliament — June 2025"
      aspect="21/9"
      color="#071e4f"
    />
  </section>

  <!-- ======== MISSION ======== -->
  <section class="section">
    <div class="container">
      <div class="about-split">
        <div class="about-split__left">
          <p class="text-label">What Is Smart Data</p>
          <AnimatedText
            tag="h2"
            class="text-h2"
            lines={[
              "Secure, standardised,",
              "consent-driven",
              "data sharing."
            ]}
          />
        </div>
        <div class="about-split__right reveal">
          <p class="text-body-lg">
            Smart data enables secure, standardised, and consent-driven sharing of data between organisations and individuals, unlocking innovation, better services, and economic growth. It creates a connected, efficient ecosystem that benefits consumers, businesses, and the wider economy.
          </p>
          <p class="text-body">
            By uniting data holders, third-party providers, service providers, regulators, and policymakers, we create collaborative data-sharing frameworks that drive innovation and trust.
          </p>
          <p class="text-body">
            Our mission is to proactively deliver scalable, market-driven solutions that anticipate regulation — enabling industry players to lead, not follow. The Data (Use and Access) Act 2025 gives the government and regulators powers to mandate data sharing across sectors including energy, retail, telecoms, and finance, unlocking an estimated £27.8 billion in economic value.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== DIVISIONS ======== -->
  <section class="section values-section">
    <div class="container">
      <SectionHeader
        label="Our Divisions"
        title="Three pillars of the smart data economy."
        align="center"
      />

      <div class="values-grid stagger-reveal">
        <div class="value-item">
          <div class="value-item__marker"></div>
          <h3 class="text-h3">SDG UK</h3>
          <p class="text-body">The collective voice and home for the smart data ecosystem. SDG UK scopes, tests, and agrees on commercially viable use cases for future smart data schemes, promotes adoption, creates standards, rules, and APIs, and advocates for smart data policies with government and regulators.</p>
        </div>

        <div class="value-item">
          <div class="value-item__marker"></div>
          <h3 class="text-h3">Smart Data Services (SDS)</h3>
          <p class="text-body">A not-for-profit company limited by guarantee, established to provide industry with the operating vehicle for regulated smart data schemes. SDS delivers technical expertise, governance frameworks, and operational infrastructure across finance, energy, telecoms, and other sectors.</p>
        </div>

        <div class="value-item">
          <div class="value-item__marker"></div>
          <h3 class="text-h3">Smart Data International (SDI)</h3>
          <p class="text-body">Responsible for promoting UK standards globally, driving cross-border interoperability, sharing best practice, and representing members' international interests across jurisdictions.</p>
        </div>

        <div class="value-item">
          <div class="value-item__marker"></div>
          <h3 class="text-h3">Transparent & Results-Driven</h3>
          <p class="text-body">We collaborate with members to understand challenges and develop tailored solutions. Our approach is transparent, results-driven, and designed to help businesses succeed in the smart data economy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== LEADERSHIP SECTION ======== -->
  <section class="section">
    <div class="container">
      <SectionHeader
        label="Leadership"
        title="Experienced leadership driving the smart data agenda."
        description="Chaired by former Minister for Smart Data, our leadership unites policymakers and industry experts to keep the UK at the forefront of data sharing."
      />

      <div class="team-grid stagger-reveal">
        <div class="team-member">
          <ImagePlaceholder
            alt="Paul Scully — Chair of Smart Data Group"
            aspect="3/4"
            color="#132450"
          />
          <h3 class="text-h3">Paul Scully</h3>
          <p class="text-caption">Chair</p>
        </div>

        <div class="team-member">
          <ImagePlaceholder
            alt="Richard Newman — Operational Lead"
            aspect="3/4"
            color="#0a1d45"
          />
          <h3 class="text-h3">Richard Newman</h3>
          <p class="text-caption">Operational Lead</p>
        </div>

        <div class="team-member">
          <ImagePlaceholder
            alt="Clare Ambrosino — Operational Lead"
            aspect="3/4"
            color="#1a3068"
          />
          <h3 class="text-h3">Clare Ambrosino</h3>
          <p class="text-caption">Operational Lead</p>
        </div>
      </div>

      <div class="divider" style="margin: var(--space-10) 0;"></div>

      <SectionHeader
        label="Advisory Board"
        title="Cross-party support at the highest level."
      />

      <div class="team-grid stagger-reveal">
        <div class="team-member">
          <ImagePlaceholder
            alt="Jonathan Ashworth — Advisory Board Member"
            aspect="3/4"
            color="#071e4f"
          />
          <h3 class="text-h3">Jonathan Ashworth</h3>
          <p class="text-caption">Advisory Board</p>
        </div>

        <div class="team-member">
          <ImagePlaceholder
            alt="Lord Iain McNicol — Advisory Board Member"
            aspect="3/4"
            color="#132450"
          />
          <h3 class="text-h3">Lord Iain McNicol</h3>
          <p class="text-caption">Advisory Board</p>
        </div>

        <div class="team-member">
          <ImagePlaceholder
            alt="Lord Martin Callanan — Advisory Board Member"
            aspect="3/4"
            color="#0a1d45"
          />
          <h3 class="text-h3">Lord Martin Callanan</h3>
          <p class="text-caption">Advisory Board</p>
        </div>

        <div class="team-member">
          <ImagePlaceholder
            alt="Sir Robbie Gibb — Advisory Board Member"
            aspect="3/4"
            color="#1a3068"
          />
          <h3 class="text-h3">Sir Robbie Gibb</h3>
          <p class="text-caption">Advisory Board</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== SECTORS STRIP ======== -->
  <section class="section-sm partners-section">
    <div class="container">
      <p class="text-caption" style="text-align: center; margin-bottom: var(--space-8);">Priority Sectors for Smart Data Schemes</p>
      <div class="partners-row reveal">
        {['Banking & Finance', 'Energy', 'Telecoms', 'Transport', 'Retail', 'Property'].map((name) => (
          <div class="partner-logo">
            <span>{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--space-24) + 80px);
  }

  .page-hero__intro {
    max-width: 680px;
    margin-top: var(--space-8);
  }

  /* --- About Split --- */
  .about-split {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-16);
  }

  .about-split__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* --- Values --- */
  .values-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .value-item {
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .value-item__marker {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
  }

  /* --- Team --- */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--grid-gap);
  }

  .team-member {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .team-member .text-h3 {
    font-size: 1.125rem;
  }

  .team-member .text-caption {
    margin-top: calc(-1 * var(--space-2));
  }

  /* --- Partners --- */
  .partners-section {
    border-bottom: 1px solid var(--color-border);
  }

  .partners-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .partner-logo {
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .partner-logo span {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .about-split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .values-grid {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .partners-row {
      justify-content: center;
    }
  }
</style>
