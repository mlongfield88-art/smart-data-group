---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
---

<Layout title="Contact" description="Get in touch with Smart Data Group — membership inquiries, partnerships, and general contact.">

  <!-- ======== PAGE HERO ======== -->
  <section class="page-hero section-lg">
    <div class="container">
      <p class="text-label reveal">Contact</p>
      <AnimatedText
        tag="h1"
        class="text-display"
        lines={[
          "Let's build the",
          "data economy",
          "together."
        ]}
      />
    </div>
  </section>

  <!-- ======== CONTACT GRID ======== -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Form -->
        <div class="contact-form reveal">
          <h2 class="text-h3" style="margin-bottom: var(--space-6);">Send us a message</h2>
          <form action="#" method="post" class="form">
            <div class="form__row">
              <div class="form__group">
                <label for="name" class="form__label text-caption">Full Name</label>
                <input type="text" id="name" name="name" class="form__input" placeholder="Jane Richardson" required />
              </div>
              <div class="form__group">
                <label for="org" class="form__label text-caption">Organization</label>
                <input type="text" id="org" name="organization" class="form__input" placeholder="Acme Corp" />
              </div>
            </div>

            <div class="form__group">
              <label for="email" class="form__label text-caption">Email</label>
              <input type="email" id="email" name="email" class="form__input" placeholder="jane@acme.com" required />
            </div>

            <div class="form__group">
              <label for="subject" class="form__label text-caption">Subject</label>
              <select id="subject" name="subject" class="form__input form__select">
                <option value="">Select a topic</option>
                <option value="membership">Membership Inquiry</option>
                <option value="sdg-uk">SDG UK</option>
                <option value="sds">Smart Data Services</option>
                <option value="sdi">Smart Data International</option>
                <option value="events">Events & Speaking</option>
                <option value="general">General Inquiry</option>
              </select>
            </div>

            <div class="form__group">
              <label for="message" class="form__label text-caption">Message</label>
              <textarea id="message" name="message" class="form__input form__textarea" rows="5" placeholder="Tell us how we can help..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary form__submit">
              Send Message <span class="btn-arrow">&rarr;</span>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-info reveal">
          <div class="contact-info__block">
            <h3 class="text-label">General Inquiries</h3>
            <a href="mailto:info@smartdatagroup.org" class="contact-info__link">info@smartdatagroup.org</a>
          </div>

          <div class="divider" style="margin: var(--space-6) 0;"></div>

          <div class="contact-info__block">
            <h3 class="text-label">Registered Office</h3>
            <p class="text-body">
              Smart Data Group<br />
              143 Tamworth Road<br />
              Long Eaton, Nottingham<br />
              United Kingdom
            </p>
            <p class="text-caption" style="margin-top: var(--space-2);">Company No. 16400779</p>
          </div>

          <div class="contact-info__block">
            <h3 class="text-label">Connect</h3>
            <div class="contact-socials">
              <a href="https://www.linkedin.com/company/smart-data-group-uk" target="_blank" rel="noopener" class="contact-info__link">LinkedIn</a>
              <a href="https://x.com/smartdatagroup" target="_blank" rel="noopener" class="contact-info__link">X / Twitter</a>
            </div>
          </div>

          <div class="divider" style="margin: var(--space-6) 0;"></div>

          <div class="img-crop" style="aspect-ratio: 4/3;">
            <img
              src="/images/parliament-portal.jpeg"
              alt="UK Parliament archway — Smart Data Group"
              style="width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--space-24) + 80px);
  }

  /* --- Contact Grid --- */
  .contact-grid {
    display: grid;
    grid-template-columns: 7fr 4fr;
    gap: var(--space-16);
  }

  /* --- Form --- */
  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form__label {
    font-size: 0.6875rem;
  }

  .form__input {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    transition: border-color var(--duration-fast) ease;
    outline: none;
  }

  .form__input::placeholder {
    color: var(--color-text-muted);
  }

  .form__input:focus {
    border-color: var(--color-accent);
  }

  .form__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237880a0' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: var(--space-10);
  }

  .form__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .form__submit {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  /* --- Info --- */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-info__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-info__link {
    font-size: 1rem;
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) ease;
    display: inline-block;
  }

  .contact-info__link:hover {
    color: var(--color-accent);
  }

  .contact-socials {
    display: flex;
    gap: var(--space-5);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
