---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
import AnimatedCard from '@/components/AnimatedCard';
import RevealSection from '@/components/RevealSection';

const articles = [
  {
    date: 'August 2025',
    category: 'Open Banking',
    title: 'SDG Welcomes FCA Announcement on Future Entity for UK Open Banking',
    excerpt: 'Smart Data Group welcomes the Financial Conduct Authority\'s latest announcement on the Future Entity for UK open banking, outlining an exciting path forward for a more unified, interoperable, and user-centric open banking ecosystem.',
    src: '/images/fca-building.jpeg',
    alt: 'Financial Conduct Authority building with data network light trails',
    featured: true,
  },
  {
    date: 'July 2025',
    category: 'Legislation',
    title: 'UK Data Reforms Unpacked: The New Smart Data Schemes',
    excerpt: 'A closer look at Part 1 of the Data (Use and Access) Act 2025, which establishes smart data schemes — putting the UK\'s Open Banking regime on a statutory footing and expanding personal data portability to other sectors.',
    src: '/images/duaa-governance.jpeg',
    alt: 'Data Use and Access Act 2025 governance framework documents',
    featured: true,
  },
  {
    date: 'June 2025',
    category: 'Launch',
    title: 'Smart Data Group Launches at UK Parliament',
    excerpt: 'Policymakers, regulators, industry leaders, and innovators came together at Parliament to celebrate the launch of the Smart Data Group — unlocking an estimated £27.8 billion in economic value.',
    src: '/images/hero-parliament.jpeg',
    alt: 'UK Parliament at twilight — Smart Data Group launch at Westminster',
  },
  {
    date: 'January 2025',
    category: 'Energy',
    title: 'Energy Smart Data Scheme Proposed in Britain',
    excerpt: 'An energy smart data scheme involving sharing customer data with authorised third parties in a secure way is under investigation, modelled on the UK\'s open banking scheme.',
    src: '/images/energy-meter.jpeg',
    alt: 'Smart energy meter displaying £27.8bn economic value with data streams',
  },
  {
    date: 'January 2025',
    category: 'Policy',
    title: 'Government Calls for Evidence on Energy Data Sharing',
    excerpt: 'The Department for Energy Security and Net Zero issued a call for evidence on the development of an energy smart data scheme to understand the potential for data sharing in the sector.',
    src: '/images/duaa-governance.jpeg',
    alt: 'Government policy documents — energy data sharing framework',
  },
  {
    date: '2025',
    category: 'Strategy',
    title: 'Smart Data 2035: The UK\'s Smart Data Strategy Published',
    excerpt: 'The UK government\'s Smart Data 2035 Strategy sets out next steps to develop a smart data economy — with schemes across finance, energy, telecoms, transport, retail, and property.',
    src: '/images/parliament-portal.jpeg',
    alt: 'Parliament archway — UK Smart Data 2035 vision',
  },
];

const featured = articles.filter((a) => a.featured);
const regular = articles.filter((a) => !a.featured);
---

<Layout title="News" description="Latest news, insights, and policy updates from Smart Data Group.">

  <!-- ======== PAGE HERO ======== -->
  <section class="page-hero section-lg">
    <div class="container">
      <p class="text-label reveal">News & Insights</p>
      <AnimatedText
        tag="h1"
        class="text-display"
        lines={[
          "The latest on UK",
          "smart data policy."
        ]}
      />
    </div>
  </section>

  <!-- ======== FEATURED ======== -->
  <section class="container">
    <div class="featured-grid">
      {featured.map((article, i) => (
        <AnimatedCard client:visible className="featured-card" index={i}>
          <a href="#" class="featured-card__link-wrap">
            <div class="featured-card__img">
              <img
                src={article.src}
                alt={article.alt}
                loading="lazy"
              />
              <div class="featured-card__img-overlay"></div>
            </div>
            <div class="featured-card__content">
              <div class="featured-card__meta">
                <span class="text-label">{article.category}</span>
                <time class="text-caption">{article.date}</time>
              </div>
              <h2 class="text-h2">{article.title}</h2>
              <p class="text-body-lg">{article.excerpt}</p>
              <span class="featured-card__link">
                Read Article <span class="btn-arrow">&rarr;</span>
              </span>
            </div>
          </a>
        </AnimatedCard>
      ))}
    </div>
  </section>

  <!-- ======== ARTICLE LIST ======== -->
  <section class="section">
    <div class="container">
      <div class="divider line-grow" style="margin-bottom: var(--space-12);"></div>

      <div class="articles-list stagger-reveal">
        {regular.map((article) => (
          <a href="#" class="article-row">
            <div class="article-row__left">
              <span class="text-label">{article.category}</span>
              <time class="text-caption">{article.date}</time>
            </div>
            <div class="article-row__center">
              <h3 class="text-h3">{article.title}</h3>
              <p class="text-body">{article.excerpt}</p>
            </div>
            <div class="article-row__right">
              <div class="img-crop" style="aspect-ratio: 3/2;">
                <img
                  src={article.src}
                  alt={article.alt}
                  style="width: 100%; height: 100%; object-fit: cover;"
                  loading="lazy"
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--space-24) + 80px);
  }

  /* --- Featured --- */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .featured-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .featured-card__link-wrap {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .featured-card__img {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .featured-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .featured-card:hover .featured-card__img img {
    transform: scale(1.05);
  }

  .featured-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 26, 83, 0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  .featured-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .featured-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .featured-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .featured-card:hover .featured-card__link .btn-arrow {
    transform: translateX(4px);
  }

  .featured-card__link .btn-arrow {
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  /* --- Article Rows --- */
  .articles-list {
    display: flex;
    flex-direction: column;
  }

  .article-row {
    display: grid;
    grid-template-columns: 160px 1fr 200px;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
    transition: all var(--duration-fast) ease;
  }

  .article-row:hover {
    padding-left: var(--space-4);
  }

  .article-row:hover .text-h3 {
    color: var(--color-accent);
  }

  .article-row__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .article-row__center {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .article-row__center .text-h3 {
    transition: color var(--duration-fast) ease;
  }

  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .article-row {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .article-row__right {
      display: none;
    }
  }
</style>
