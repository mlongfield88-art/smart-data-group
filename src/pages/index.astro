---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
import SectionHeader from '@/components/SectionHeader.astro';
---

<Layout title="Home" description="Smart Data Group — Unlocking £27.8 billion in economic value through secure, standardised data sharing across the UK economy.">

  <!-- ======== HERO ======== -->
  <section class="hero section-lg">
    <div class="container">
      <div class="hero__content">
        <p class="text-label reveal">Secure, Standardised, Consent-Driven Data Sharing</p>

        <AnimatedText
          tag="h1"
          class="text-display hero__headline"
          lines={[
            "Unlocking the power",
            "of Smart Data for",
            "the UK economy."
          ]}
        />

        <div class="hero__sub reveal">
          <p class="text-body-lg">
            Smart Data enables secure, standardised, and consent-driven sharing of data between organisations and individuals — unlocking innovation, better services, and economic growth worth an estimated £27.8 billion.
          </p>
          <div class="hero__actions">
            <a href="/about" class="btn btn-primary">
              Learn More <span class="btn-arrow">&rarr;</span>
            </a>
            <a href="/contact" class="btn btn-outline">
              Become a Member <span class="btn-arrow">&rarr;</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero__visual parallax img-full-bleed" data-speed="-0.08">
        <div class="img-crop clip-reveal" style="aspect-ratio: 2.5/1;">
          <img
            src="/images/hero-parliament.jpeg"
            alt="UK Parliament and Westminster at twilight — Smart Data Group launch event"
            style="width: 100%; height: 100%; object-fit: cover;"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ======== MARQUEE STRIP ======== -->
  <div class="marquee-strip">
    <div class="marquee-strip__inner">
      <span>Open Banking</span>
      <span class="marquee-dot"></span>
      <span>Open Finance</span>
      <span class="marquee-dot"></span>
      <span>Energy Data</span>
      <span class="marquee-dot"></span>
      <span>Telecoms</span>
      <span class="marquee-dot"></span>
      <span>Trust Frameworks</span>
      <span class="marquee-dot"></span>
      <span>Open Banking</span>
      <span class="marquee-dot"></span>
      <span>Open Finance</span>
      <span class="marquee-dot"></span>
      <span>Energy Data</span>
      <span class="marquee-dot"></span>
      <span>Telecoms</span>
      <span class="marquee-dot"></span>
      <span>Trust Frameworks</span>
      <span class="marquee-dot"></span>
    </div>
  </div>

  <!-- ======== CAPABILITIES ======== -->
  <section class="section" id="capabilities">
    <div class="container">
      <SectionHeader
        label="Our Divisions"
        title="A comprehensive delivery organisation for smart data."
        description="We empower members to design and implement smart data schemes while shaping and ensuring compliance with regulatory requirements — uniting data holders, third-party providers, regulators, and policymakers."
      />

      <div class="capabilities-grid stagger-reveal">
        <div class="capability-card card">
          <span class="capability-number">01</span>
          <h3 class="text-h3">SDG UK</h3>
          <p class="text-body">The collective voice and home for the smart data ecosystem — convening industry leaders, advocating for policy, and developing commercially viable use cases for smart data schemes.</p>
        </div>

        <div class="capability-card card">
          <span class="capability-number">02</span>
          <h3 class="text-h3">Smart Data Services</h3>
          <p class="text-body">A not-for-profit implementation entity that operates regulated and commercial smart data schemes, providing technical expertise, governance frameworks, and operational infrastructure.</p>
        </div>

        <div class="capability-card card">
          <span class="capability-number">03</span>
          <h3 class="text-h3">Smart Data International</h3>
          <p class="text-body">Promoting UK standards globally, driving cross-border interoperability, sharing best practice, and representing members' international interests.</p>
        </div>

        <div class="capability-card card">
          <span class="capability-number">04</span>
          <h3 class="text-h3">Membership</h3>
          <p class="text-body">Join a growing network of data holders, third-party providers, consumer groups, regulators, and innovators shaping the future of data sharing across the UK economy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== IMPACT / STATS ======== -->
  <section class="stats-section section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat reveal">
          <span class="stat__number counter" data-target="27" data-suffix=".8bn">0</span>
          <span class="stat__label text-caption">Estimated Economic Value (£)</span>
        </div>
        <div class="stat reveal">
          <span class="stat__number counter" data-target="1" data-suffix=" in 5">0</span>
          <span class="stat__label text-caption">UK Consumers Use Open Banking</span>
        </div>
        <div class="stat reveal">
          <span class="stat__number counter" data-target="6" data-suffix="+">0</span>
          <span class="stat__label text-caption">Priority Sectors</span>
        </div>
        <div class="stat reveal">
          <span class="stat__number counter" data-target="12" data-suffix="m">0</span>
          <span class="stat__label text-caption">Government Investment (£)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== EDITORIAL SPLIT ======== -->
  <section class="editorial section">
    <div class="container">
      <div class="editorial__grid">
        <div class="editorial__media">
          <div class="img-crop clip-reveal" style="aspect-ratio: 4/5;">
            <img
              src="/images/parliament-portal.jpeg"
              alt="UK Parliament gothic archway — Smart Data Group vision portal"
              style="width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
          </div>
        </div>
        <div class="editorial__content">
          <p class="text-label">Why Smart Data Matters</p>
          <AnimatedText
            tag="h2"
            class="text-h2"
            lines={[
              "The UK is entering",
              "a data-sharing",
              "revolution."
            ]}
          />
          <p class="text-body-lg editorial__desc">
            The Data (Use and Access) Act 2025 gives the government and regulators powers to mandate data sharing across sectors including energy, retail, telecoms, and finance.
          </p>
          <p class="text-body editorial__desc">
            Smart Data Group proactively delivers scalable, market-driven solutions that anticipate regulation — enabling industry players to lead, not follow. We create collaborative data-sharing frameworks that drive innovation and trust.
          </p>
          <a href="/about" class="btn btn-accent">
            About SDG <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== LATEST NEWS PREVIEW ======== -->
  <section class="section news-preview">
    <div class="container">
      <SectionHeader
        label="Latest"
        title="News & Insights"
      />

      <div class="news-preview__grid stagger-reveal">
        <a href="/news" class="news-card">
          <div class="img-crop clip-reveal" style="aspect-ratio: 16/10;">
            <img
              src="/images/fca-building.jpeg"
              alt="Financial Conduct Authority building with data network light trails"
              style="width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
          </div>
          <div class="news-card__content">
            <time class="text-caption">August 2025</time>
            <h3 class="text-h3">SDG Welcomes FCA Announcement on Future Entity for UK Open Banking</h3>
            <p class="text-body">A critical step towards a more unified, interoperable, and user-centric open banking ecosystem.</p>
          </div>
        </a>

        <a href="/news" class="news-card">
          <div class="img-crop clip-reveal" style="aspect-ratio: 16/10;">
            <img
              src="/images/duaa-governance.jpeg"
              alt="Data Use and Access Act 2025 governance framework documents"
              style="width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
          </div>
          <div class="news-card__content">
            <time class="text-caption">July 2025</time>
            <h3 class="text-h3">UK Data Reforms Unpacked: The New Smart Data Schemes</h3>
            <p class="text-body">A closer look at Part 1 of the Data (Use and Access) Act 2025 and its smart data scheme provisions.</p>
          </div>
        </a>

        <a href="/news" class="news-card">
          <div class="img-crop clip-reveal" style="aspect-ratio: 16/10;">
            <img
              src="/images/energy-meter.jpeg"
              alt="Smart energy meter displaying £27.8bn economic value with data streams"
              style="width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
          </div>
          <div class="news-card__content">
            <time class="text-caption">January 2025</time>
            <h3 class="text-h3">Energy Smart Data Scheme Proposed in Britain</h3>
            <p class="text-body">An energy smart data scheme involving sharing customer data with authorised third parties is under investigation.</p>
          </div>
        </a>
      </div>

      <div class="news-preview__cta reveal">
        <a href="/news" class="btn btn-outline">
          View All News <span class="btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== CTA BANNER ======== -->
  <section class="cta-banner section-lg">
    <div class="container">
      <div class="cta-banner__inner reveal">
        <AnimatedText
          tag="h2"
          class="text-h1"
          lines={[
            "Lead, not follow —",
            "join Smart Data Group."
          ]}
        />
        <p class="text-body-lg cta-banner__desc">
          Unite with data holders, third-party providers, regulators, and policymakers to shape the future of smart data in the UK and beyond.
        </p>
        <div class="cta-banner__actions">
          <a href="/contact" class="btn btn-primary">
            Become a Member <span class="btn-arrow">&rarr;</span>
          </a>
          <a href="/events" class="btn btn-outline">
            Upcoming Events <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* --- Hero --- */
  .hero {
    padding-top: calc(var(--space-24) + 80px);
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .hero__headline {
    margin-top: var(--space-6);
  }

  .hero__sub {
    margin-top: var(--space-8);
    max-width: 580px;
  }

  .hero__sub .text-body-lg {
    margin-bottom: var(--space-8);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__visual {
    max-width: none;
  }

  /* --- Marquee Strip --- */
  .marquee-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    overflow: hidden;
  }

  .marquee-strip__inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    white-space: nowrap;
    animation: marquee 25s linear infinite;
    width: max-content;
  }

  .marquee-strip__inner span {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .marquee-dot {
    width: 4px !important;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    display: inline-block;
    flex-shrink: 0;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* --- Capabilities --- */
  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .capability-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .capability-number {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .capability-card .text-h3 {
    margin-top: var(--space-2);
  }

  /* --- Stats --- */
  .stats-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--grid-gap);
    text-align: center;
  }

  .stat__number {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    display: block;
    line-height: 1;
  }

  .stat__label {
    display: block;
    margin-top: var(--space-3);
  }

  /* --- Editorial Split --- */
  .editorial__grid {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-16);
    align-items: center;
  }

  .editorial__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .editorial__content .text-h2 {
    margin-top: var(--space-3);
  }

  .editorial__desc {
    max-width: 520px;
  }

  .editorial__content .btn {
    margin-top: var(--space-4);
    align-self: flex-start;
  }

  /* --- News Preview --- */
  .news-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
  }

  .news-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .news-card:hover {
    transform: translateY(-4px);
  }

  .news-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .news-card .text-h3 {
    transition: color var(--duration-fast) ease;
  }

  .news-card:hover .text-h3 {
    color: var(--color-accent);
  }

  .news-card .img-crop {
    border-radius: var(--radius-sm);
  }

  .news-preview__cta {
    text-align: center;
    margin-top: var(--space-12);
  }

  /* --- CTA Banner --- */
  .cta-banner {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
  }

  .cta-banner__inner {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-banner__desc {
    max-width: 560px;
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-4);
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .capabilities-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }

    .editorial__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .news-preview__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
