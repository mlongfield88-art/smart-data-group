---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ParallaxImage from '@/components/ParallaxImage';
import AnimatedCard from '@/components/AnimatedCard';
import AnimatedCounter from '@/components/AnimatedCounter';
import RevealSection from '@/components/RevealSection';
---

<Layout title="Home" description="Smart Data Group — Unlocking £27.8 billion in economic value through secure, standardised data sharing across the UK economy.">

  <!-- ======== HERO — Full viewport with image background ======== -->
  <section class="hero">
    <div class="hero__bg">
      <img
        src="/images/hero-parliament.jpeg"
        alt="UK Parliament and Westminster at twilight"
        loading="eager"
      />
      <div class="hero__overlay"></div>
    </div>
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="text-label reveal">Secure, Standardised, Consent-Driven Data Sharing</p>

        <AnimatedText
          tag="h1"
          class="text-display hero__headline"
          lines={[
            "Unlocking the power",
            "of Smart Data for",
            "the UK economy."
          ]}
        />

        <div class="hero__sub reveal">
          <p class="text-body-lg">
            Smart Data enables secure, standardised, and consent-driven sharing of data between organisations and individuals — unlocking innovation, better services, and economic growth worth an estimated £27.8 billion.
          </p>
          <div class="hero__actions">
            <a href="/about" class="btn btn-primary">
              Learn More <span class="btn-arrow">&rarr;</span>
            </a>
            <a href="/contact" class="btn btn-outline">
              Become a Member <span class="btn-arrow">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="hero__scroll-hint">
      <span></span>
    </div>
  </section>

  <!-- ======== MARQUEE STRIP ======== -->
  <div class="marquee-strip">
    <div class="marquee-strip__inner">
      <span>Open Banking</span>
      <span class="marquee-dot"></span>
      <span>Open Finance</span>
      <span class="marquee-dot"></span>
      <span>Energy Data</span>
      <span class="marquee-dot"></span>
      <span>Telecoms</span>
      <span class="marquee-dot"></span>
      <span>Trust Frameworks</span>
      <span class="marquee-dot"></span>
      <span>Open Banking</span>
      <span class="marquee-dot"></span>
      <span>Open Finance</span>
      <span class="marquee-dot"></span>
      <span>Energy Data</span>
      <span class="marquee-dot"></span>
      <span>Telecoms</span>
      <span class="marquee-dot"></span>
      <span>Trust Frameworks</span>
      <span class="marquee-dot"></span>
    </div>
  </div>

  <!-- ======== CAPABILITIES — Framer-motion cards ======== -->
  <section class="section" id="capabilities">
    <div class="container">
      <SectionHeader
        label="Our Divisions"
        title="A comprehensive delivery organisation for smart data."
        description="We empower members to design and implement smart data schemes while shaping and ensuring compliance with regulatory requirements — uniting data holders, third-party providers, regulators, and policymakers."
      />

      <div class="capabilities-grid">
        <AnimatedCard client:visible className="capability-card card" index={0}>
          <span class="capability-number">01</span>
          <h3 class="text-h3">SDG UK</h3>
          <p class="text-body">The collective voice and home for the smart data ecosystem — convening industry leaders, advocating for policy, and developing commercially viable use cases for smart data schemes.</p>
        </AnimatedCard>

        <AnimatedCard client:visible className="capability-card card" index={1}>
          <span class="capability-number">02</span>
          <h3 class="text-h3">Smart Data Services</h3>
          <p class="text-body">A not-for-profit implementation entity that operates regulated and commercial smart data schemes, providing technical expertise, governance frameworks, and operational infrastructure.</p>
        </AnimatedCard>

        <AnimatedCard client:visible className="capability-card card" index={2}>
          <span class="capability-number">03</span>
          <h3 class="text-h3">Smart Data International</h3>
          <p class="text-body">Promoting UK standards globally, driving cross-border interoperability, sharing best practice, and representing members' international interests.</p>
        </AnimatedCard>

        <AnimatedCard client:visible className="capability-card card" index={3}>
          <span class="capability-number">04</span>
          <h3 class="text-h3">Membership</h3>
          <p class="text-body">Join a growing network of data holders, third-party providers, consumer groups, regulators, and innovators shaping the future of data sharing across the UK economy.</p>
        </AnimatedCard>
      </div>
    </div>
  </section>

  <!-- ======== STATS — Framer-motion counters ======== -->
  <section class="stats-section section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <AnimatedCounter client:visible target={27} suffix=".8bn" prefix="£" className="stat__number" />
          <span class="stat__label text-caption">Estimated Economic Value</span>
        </div>
        <div class="stat">
          <AnimatedCounter client:visible target={1} suffix=" in 5" className="stat__number" />
          <span class="stat__label text-caption">UK Consumers Use Open Banking</span>
        </div>
        <div class="stat">
          <AnimatedCounter client:visible target={6} suffix="+" className="stat__number" />
          <span class="stat__label text-caption">Priority Sectors</span>
        </div>
        <div class="stat">
          <AnimatedCounter client:visible target={12} suffix="m" prefix="£" className="stat__number" />
          <span class="stat__label text-caption">Government Investment</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== EDITORIAL — Parallax image with gradient bleed ======== -->
  <section class="editorial section">
    <div class="container">
      <div class="editorial__grid">
        <div class="editorial__media">
          <ParallaxImage
            client:visible
            src="/images/parliament-portal.jpeg"
            alt="UK Parliament gothic archway — Smart Data Group vision portal"
            aspectRatio="4/5"
            speed={0.12}
            overlayDirection="both"
          />
        </div>
        <RevealSection client:visible direction="right" className="editorial__content">
          <p class="text-label">Why Smart Data Matters</p>
          <h2 class="text-h2" style="margin-top: var(--space-3);">The UK is entering a data-sharing revolution.</h2>
          <p class="text-body-lg editorial__desc">
            The Data (Use and Access) Act 2025 gives the government and regulators powers to mandate data sharing across sectors including energy, retail, telecoms, and finance.
          </p>
          <p class="text-body editorial__desc">
            Smart Data Group proactively delivers scalable, market-driven solutions that anticipate regulation — enabling industry players to lead, not follow.
          </p>
          <a href="/about" class="btn btn-accent">
            About SDG <span class="btn-arrow">&rarr;</span>
          </a>
        </RevealSection>
      </div>
    </div>
  </section>

  <!-- ======== FULL-BLEED IMAGE BREAK ======== -->
  <ParallaxImage
    client:visible
    src="/images/fca-building.jpeg"
    alt="Financial Conduct Authority — data network connections"
    aspectRatio="3/1"
    speed={0.2}
    overlayDirection="both"
  />

  <!-- ======== LATEST NEWS ======== -->
  <section class="section news-preview">
    <div class="container">
      <SectionHeader
        label="Latest"
        title="News & Insights"
      />

      <div class="news-preview__grid">
        <AnimatedCard client:visible className="news-card" index={0} hoverGlow={false}>
          <a href="/news" class="news-card__link">
            <div class="news-card__img">
              <img src="/images/fca-building.jpeg" alt="FCA building with data network light trails" loading="lazy" />
              <div class="news-card__img-overlay"></div>
            </div>
            <div class="news-card__content">
              <time class="text-caption">August 2025</time>
              <h3 class="text-h3">SDG Welcomes FCA Announcement on Future Entity for UK Open Banking</h3>
              <p class="text-body">A critical step towards a more unified, interoperable, and user-centric open banking ecosystem.</p>
            </div>
          </a>
        </AnimatedCard>

        <AnimatedCard client:visible className="news-card" index={1} hoverGlow={false}>
          <a href="/news" class="news-card__link">
            <div class="news-card__img">
              <img src="/images/duaa-governance.jpeg" alt="Data Use and Access Act 2025 documents" loading="lazy" />
              <div class="news-card__img-overlay"></div>
            </div>
            <div class="news-card__content">
              <time class="text-caption">July 2025</time>
              <h3 class="text-h3">UK Data Reforms Unpacked: The New Smart Data Schemes</h3>
              <p class="text-body">A closer look at Part 1 of the Data (Use and Access) Act 2025 and its smart data scheme provisions.</p>
            </div>
          </a>
        </AnimatedCard>

        <AnimatedCard client:visible className="news-card" index={2} hoverGlow={false}>
          <a href="/news" class="news-card__link">
            <div class="news-card__img">
              <img src="/images/energy-meter.jpeg" alt="Smart energy meter with data streams" loading="lazy" />
              <div class="news-card__img-overlay"></div>
            </div>
            <div class="news-card__content">
              <time class="text-caption">January 2025</time>
              <h3 class="text-h3">Energy Smart Data Scheme Proposed in Britain</h3>
              <p class="text-body">An energy smart data scheme involving sharing customer data with authorised third parties is under investigation.</p>
            </div>
          </a>
        </AnimatedCard>
      </div>

      <div class="news-preview__cta reveal">
        <a href="/news" class="btn btn-outline">
          View All News <span class="btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== CTA BANNER ======== -->
  <section class="cta-banner section-lg">
    <div class="cta-banner__bg">
      <img src="/images/hero-parliament.jpeg" alt="" loading="lazy" />
      <div class="cta-banner__bg-overlay"></div>
    </div>
    <div class="container">
      <RevealSection client:visible className="cta-banner__inner" direction="up">
        <h2 class="text-h1">Lead, not follow — join Smart Data Group.</h2>
        <p class="text-body-lg cta-banner__desc">
          Unite with data holders, third-party providers, regulators, and policymakers to shape the future of smart data in the UK and beyond.
        </p>
        <div class="cta-banner__actions">
          <a href="/contact" class="btn btn-primary">
            Become a Member <span class="btn-arrow">&rarr;</span>
          </a>
          <a href="/events" class="btn btn-outline">
            Upcoming Events <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </RevealSection>
    </div>
  </section>

</Layout>

<style>
  /* --- Hero — Full viewport immersive --- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--space-16);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    transform-origin: top left;
    filter: brightness(0.6) saturate(0.35) hue-rotate(10deg);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, #051a53 0%, rgba(5, 26, 83, 0.75) 30%, rgba(5, 26, 83, 0.55) 60%, rgba(5, 26, 83, 0.65) 100%);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
  }

  .hero__content {
    max-width: 780px;
    padding-top: calc(var(--space-24) + 100px);
  }

  .hero__headline {
    margin-top: var(--space-6);
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.3);
  }

  .hero__sub {
    margin-top: var(--space-8);
    max-width: 580px;
  }

  .hero__sub .text-body-lg {
    margin-bottom: var(--space-8);
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.2);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Scroll hint animation */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .hero__scroll-hint span {
    display: block;
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 12px;
    position: relative;
  }

  .hero__scroll-hint span::after {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 2px;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: translateX(-50%) translateY(0); }
    50% { opacity: 0.3; transform: translateX(-50%) translateY(12px); }
  }

  /* --- Marquee Strip --- */
  .marquee-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    overflow: hidden;
  }

  .marquee-strip__inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    white-space: nowrap;
    animation: marquee 25s linear infinite;
    width: max-content;
  }

  .marquee-strip__inner span {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .marquee-dot {
    width: 4px !important;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    display: inline-block;
    flex-shrink: 0;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* --- Capabilities — glass card style --- */
  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .capability-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease;
  }

  .capability-card:hover {
    border-color: var(--color-accent);
  }

  .capability-number {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .capability-card .text-h3 {
    margin-top: var(--space-2);
  }

  /* --- Stats --- */
  .stats-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--grid-gap);
    text-align: center;
  }

  .stat__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    display: block;
    line-height: 1;
  }

  .stat__label {
    display: block;
    margin-top: var(--space-3);
  }

  /* --- Editorial Split --- */
  .editorial__grid {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-16);
    align-items: center;
  }

  .editorial__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .editorial__desc {
    max-width: 520px;
  }

  .editorial__content .btn {
    margin-top: var(--space-4);
    align-self: flex-start;
  }

  /* --- News Cards — image overlay gradient --- */
  .news-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
  }

  .news-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    color: inherit;
    text-decoration: none;
  }

  .news-card__img {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .news-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    transform-origin: top left;
    transition: transform 0.6s var(--ease-out-expo);
    filter: brightness(0.45) saturate(0.4) hue-rotate(10deg);
  }

  .news-card:hover .news-card__img img {
    transform: scale(1.12);
    transform-origin: top left;
  }

  .news-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 26, 83, 0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  .news-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .news-card .text-h3 {
    transition: color var(--duration-fast) ease;
  }

  .news-card:hover .text-h3 {
    color: var(--color-accent);
  }

  .news-preview__cta {
    text-align: center;
    margin-top: var(--space-12);
  }

  /* --- CTA Banner — image background --- */
  .cta-banner {
    position: relative;
    overflow: hidden;
    border-top: none;
    background: none;
  }

  .cta-banner__bg {
    position: absolute;
    inset: 0;
  }

  .cta-banner__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    transform-origin: top left;
    filter: brightness(0.45) saturate(0.4) hue-rotate(10deg);
  }

  .cta-banner__bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(5, 26, 83, 0.88);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .cta-banner__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-banner__desc {
    max-width: 560px;
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-4);
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .hero {
      min-height: 85vh;
    }

    .hero__content {
      padding-top: calc(var(--space-16) + 80px);
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }

    .editorial__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .news-preview__grid {
      grid-template-columns: 1fr;
    }
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .marquee-strip__inner {
      animation: none;
    }

    .hero__scroll-hint span::after {
      animation: none;
    }

    .news-card__img img {
      transition: none;
    }
  }
</style>
