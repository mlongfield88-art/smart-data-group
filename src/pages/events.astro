---
import Layout from '@/layouts/Layout.astro';
import AnimatedText from '@/components/AnimatedText.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import RevealSection from '@/components/RevealSection';

const upcomingEvents = [
  {
    date: '2026',
    title: 'Smart Data Economy Conference 2026',
    location: 'London, UK',
    type: 'Conference',
    description: 'Bringing together policymakers, regulators, industry leaders, and innovators to explore the future of smart data schemes across the UK economy.',
    src: '/images/hero-parliament.jpeg',
    alt: 'UK Parliament — Smart Data Group conference venue',
  },
  {
    date: '2026',
    title: 'Open Finance Roadmap Workshop',
    location: 'London, UK',
    type: 'Workshop',
    description: 'Working with the FCA to set out the Open Finance roadmap, extending the benefits of Open Banking to mortgages, pensions, investments, and savings.',
    src: '/images/fca-building.jpeg',
    alt: 'FCA building — Open Finance workshop venue',
  },
  {
    date: '2026',
    title: 'Transport Data Sharing: Call for Evidence',
    location: 'Virtual',
    type: 'Consultation',
    description: 'The government launches a call for evidence to understand the value of a smart data scheme in the transport sector.',
    src: '/images/duaa-governance.jpeg',
    alt: 'Policy documents — transport data sharing consultation',
  },
];

const pastEvents = [
  {
    date: 'June 2025',
    title: 'Smart Data Group Launch at UK Parliament',
    location: 'Westminster, London',
    attendees: '200+',
  },
  {
    date: 'June 2025',
    title: 'Data (Use and Access) Act 2025 — Industry Briefing',
    location: 'London, UK',
    attendees: '150+',
  },
  {
    date: 'January 2025',
    title: 'Energy Smart Data Scheme — Call for Evidence Launch',
    location: 'Virtual',
    attendees: '300+',
  },
];
---

<Layout title="Events" description="Upcoming conferences, workshops, and consultations from Smart Data Group.">

  <!-- ======== PAGE HERO ======== -->
  <section class="page-hero section-lg">
    <div class="container">
      <p class="text-label reveal">Events</p>
      <AnimatedText
        tag="h1"
        class="text-display"
        lines={[
          "Where the smart",
          "data economy",
          "convenes."
        ]}
      />
      <p class="text-body-lg page-hero__intro reveal">
        From parliamentary launches to sector-specific workshops, SDG events bring together the people shaping the future of trusted data sharing in the UK.
      </p>
    </div>
  </section>

  <!-- ======== UPCOMING EVENTS ======== -->
  <section class="section">
    <div class="container">
      <SectionHeader
        label="Upcoming"
        title="Mark your calendar."
      />

      <div class="events-list stagger-reveal">
        {upcomingEvents.map((event) => (
          <div class="event-card">
            <div class="event-card__media">
              <div class="event-card__img">
                <img
                  src={event.src}
                  alt={event.alt}
                  loading="lazy"
                />
                <div class="event-card__img-overlay"></div>
              </div>
            </div>
            <div class="event-card__content">
              <div class="event-card__meta">
                <span class="text-label">{event.type}</span>
                <time class="text-caption">{event.date}</time>
              </div>
              <h3 class="text-h2">{event.title}</h3>
              <p class="event-card__location text-caption">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                {event.location}
              </p>
              <p class="text-body">{event.description}</p>
              <a href="/contact" class="btn btn-primary event-card__btn">
                Register Interest <span class="btn-arrow">&rarr;</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======== PAST EVENTS ======== -->
  <section class="section past-events">
    <div class="container">
      <SectionHeader
        label="Archive"
        title="Past events."
      />

      <div class="past-events__table stagger-reveal">
        <div class="past-events__header">
          <span class="text-caption">Date</span>
          <span class="text-caption">Event</span>
          <span class="text-caption">Location</span>
          <span class="text-caption">Attendees</span>
        </div>

        {pastEvents.map((event) => (
          <div class="past-event-row">
            <time class="text-body">{event.date}</time>
            <span class="text-body" style="color: var(--color-text-primary); font-weight: 500;">{event.title}</span>
            <span class="text-body">{event.location}</span>
            <span class="text-body">{event.attendees}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======== CTA ======== -->
  <section class="section-lg cta-banner">
    <div class="container">
      <div class="cta-inner reveal" style="text-align: center; max-width: 640px; margin: 0 auto;">
        <p class="text-label">Host With Us</p>
        <h2 class="text-h2" style="margin-top: var(--space-4);">Interested in co-hosting an event or speaking at one of ours?</h2>
        <a href="/contact" class="btn btn-accent" style="margin-top: var(--space-8);">
          Get in Touch <span class="btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--space-24) + 80px);
  }

  .page-hero__intro {
    max-width: 640px;
    margin-top: var(--space-8);
  }

  /* --- Event Cards --- */
  .events-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .event-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .event-card:last-child {
    border-bottom: none;
  }

  .event-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .event-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .event-card__location {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .event-card__location svg {
    flex-shrink: 0;
  }

  .event-card__img {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .event-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
    filter: brightness(0.5) saturate(0.15) contrast(0.85);
  }

  .event-card__img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #051a53;
    mix-blend-mode: color;
    opacity: 1;
    pointer-events: none;
    z-index: 1;
  }

  .event-card:hover .event-card__img img {
    transform: scale(1.05);
  }

  .event-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 26, 83, 0.5) 0%, transparent 50%);
    pointer-events: none;
  }

  .event-card__btn {
    align-self: flex-start;
    margin-top: var(--space-4);
  }

  /* --- Past Events Table --- */
  .past-events {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
  }

  .past-events__header,
  .past-event-row {
    display: grid;
    grid-template-columns: 180px 1fr 200px 100px;
    gap: var(--space-6);
    padding: var(--space-5) 0;
  }

  .past-events__header {
    border-bottom: 1px solid var(--color-border-hover);
  }

  .past-event-row {
    border-bottom: 1px solid var(--color-border);
  }

  /* --- CTA --- */
  .cta-banner {
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .event-card {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .past-events__header {
      display: none;
    }

    .past-event-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }
  }
</style>
